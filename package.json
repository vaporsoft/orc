{
  "name": "@vaporsoft/orc",
  "version": "1.0.0-alpha.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @orc/server dev",
    "dev:ui": "bun run --filter @orc/ui dev",
    "build": "bun run --filter @orc/ui build && bun run --filter @orc/server build",
    "build:ui": "bun run --filter @orc/ui build",
    "build:server": "bun run --filter @orc/server build",
    "start": "bun run --filter @orc/server start",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "author": "vaporsoft",
  "license": "UNLICENSED"
}
