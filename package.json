{
  "name": "pr-pilot",
  "version": "0.1.0",
  "description": "Automate PR feedback loops — poll reviews & CI, fix with Claude Code, push, repeat.",
  "type": "module",
  "bin": "./dist/bin/pr-pilot.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
